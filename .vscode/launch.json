{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter: Dev",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define",
        "ENV=dev",
        "--web-port",
        "44785"
      ]
    },
    {
      "name": "Flutter: Prod",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "--dart-define",
        "ENV=prod"
      ]
    },
    {
      "name": "Flutter: Web (Chrome - Dev)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "args": [
        "-d",
        "chrome",
        "--web-port",
        "44785",
        "--dart-define",
        "ENV=dev"
      ]
    }
  ]
}
